            "Aruba A1"      { return x9 }
            "Cebu A0"       -
            "Cebu B0"       -
            "Cebu B1"       { return x9 }
            "Sicily A0"     -
            "Sicily B0"     { return x9 }
            "Sicily B1"     { return x9 }
            "Turks A0"      -
            "Turks B0"      { return x9 }
