            "Turks A0"      { return 0x100001864 }
            "Turks B0"      { return 0x100001884 }
            "Crete A0"      -
            "Crete B1"      { return 0x1000007D0 }
            "Coll A0"       -
            "Coll B0"       { return 0x10000079C }
            default         { return 0 }
        }
    }

    proc override_boot_selector_reg {} {
        variable soc
        switch $soc {
            "Turks A0"      -
            "Turks B0"      { return x20 }
            "Crete A0"      -
            "Crete B1"      { return x0 }
            "Coll A0"       -
            "Coll B0"       { return x27 }
            default {
                data_provider_error
            }
